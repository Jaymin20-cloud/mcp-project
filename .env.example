# Anthropic API (required for MCP client orchestration)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub API (required for GitHub tools)
GITHUB_TOKEN=ghp_...

# RAG configuration
RAG_INDEX_PATH=./data/index
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# Server
MCP_SERVER_NAME=codebase-mcp-server
MCP_TRANSPORT=stdio

# Client tracing
TRACE_OUTPUT_DIR=./traces
TRACE_ENABLED=true

# Claude model
CLAUDE_MODEL=claude-sonnet-4-20250514
